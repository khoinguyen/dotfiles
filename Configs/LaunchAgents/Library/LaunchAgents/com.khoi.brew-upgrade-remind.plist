<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.khoi.brew-upgrade-remind</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/open</string>
        <string>-na</string>
        <string>Ghostty</string>
        <string>--args</string>
        <string>--wait-after-command=true</string>
        <string>-e</string>
        <string>/Users/khoinguyen/.local/bin/brew-upgrade-run</string>
    </array>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>16</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>
    <key>StandardOutPath</key>
    <string>/Users/khoinguyen/Library/Logs/brew-upgrade-remind.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/khoinguyen/Library/Logs/brew-upgrade-remind.log</string>
</dict>
</plist>
